*.iml
.gradle
/local.properties
# Ignore IDE metadata by default, but keep the shared copyright profile
# so all contributors get the same GPL header template.
/.idea/*
!/.idea/copyright/
.DS_Store
/build
# The standard AGP output dir `app/build/` is already covered by
# `app/.gitignore`. The entries below catch Android Studio "Run"
# builds that drop their APKs into `app/debug/` and `app/release/`
# directly, alongside the module rather than under `build/`.
/app/debug
/app/release
/captures
.externalNativeBuild
.cxx
local.properties
