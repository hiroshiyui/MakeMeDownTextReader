<?xml version="1.0" encoding="utf-8"?><!--
    Monochrome variant of the launcher icon for Android 13+ themed
    icons. Same geometry as ic_launcher_foreground but rendered in a
    single tintable colour (black) so the launcher can recolor it to
    match the user's theme.

    Page fills are left transparent so only the line-work is tinted —
    a fully filled book would produce a big blocky shape when themed.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Left page outline -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#000000"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M30,52 L54,50 L54,73 L30,75 Z" />

    <!-- Right page outline -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#000000"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M54,50 L78,52 L78,75 L54,73 Z" />

    <!-- Text lines, left page -->
    <path
        android:strokeColor="#000000"
        android:strokeWidth="1.8"
        android:strokeLineCap="round"
        android:pathData="M34,58 L50,57" />
    <path
        android:strokeColor="#000000"
        android:strokeWidth="1.8"
        android:strokeLineCap="round"
        android:pathData="M34,63 L50,62" />
    <path
        android:strokeColor="#000000"
        android:strokeWidth="1.8"
        android:strokeLineCap="round"
        android:pathData="M34,68 L48,67" />

    <!-- Text lines, right page -->
    <path
        android:strokeColor="#000000"
        android:strokeWidth="1.8"
        android:strokeLineCap="round"
        android:pathData="M58,57 L74,58" />
    <path
        android:strokeColor="#000000"
        android:strokeWidth="1.8"
        android:strokeLineCap="round"
        android:pathData="M58,62 L74,63" />
    <path
        android:strokeColor="#000000"
        android:strokeWidth="1.8"
        android:strokeLineCap="round"
        android:pathData="M58,67 L72,68" />

    <!-- Glasses: left lens -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#000000"
        android:strokeWidth="3"
        android:pathData="M40,39 m-8,0 a8,8 0 1,0 16,0 a8,8 0 1,0 -16,0" />

    <!-- Glasses: right lens -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#000000"
        android:strokeWidth="3"
        android:pathData="M68,39 m-8,0 a8,8 0 1,0 16,0 a8,8 0 1,0 -16,0" />

    <!-- Glasses: bridge -->
    <path
        android:strokeColor="#000000"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:pathData="M48,39 L60,39" />

    <!-- Glasses: earpiece stubs -->
    <path
        android:strokeColor="#000000"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:pathData="M32,39 L28,41" />
    <path
        android:strokeColor="#000000"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:pathData="M76,39 L80,41" />
</vector>
