<!--
    Monochrome variant of the launcher icon for Android 13+ themed
    icons. Single tintable colour (black) so the launcher can recolour
    it to match the user's theme.

    Kept deliberately minimal: just the "MMD" wordmark, centred
    vertically and sliced by horizontal scanline stripes. The clip-path
    defines the seven visible stripe regions as disjoint rectangles;
    any part of the letters outside the stripes is clipped to
    transparent, so the launcher's theme tint shows through the gaps
    without needing a painted background.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <group>
        <clip-path
            android:pathData="M35,44 L75,44 L75,46 L35,46 Z M35,47 L75,47 L75,49 L35,49 Z M35,50 L75,50 L75,52 L35,52 Z M35,53 L75,53 L75,55 L35,55 Z M35,56 L75,56 L75,58 L35,58 Z M35,59 L75,59 L75,61 L35,61 Z M35,62 L75,62 L75,64 L35,64 Z" />

        <!-- Letter M (left) -->
        <path
            android:fillColor="#000000"
            android:fillType="evenOdd"
            android:pathData="M37,44 L47,44 L47,64 L37,64 Z M39.5,44 L44.5,44 L42,54 Z M39.5,54 L44.5,54 L44.5,64 L39.5,64 Z" />

        <!-- Letter M (right) -->
        <path
            android:fillColor="#000000"
            android:fillType="evenOdd"
            android:pathData="M50,44 L60,44 L60,64 L50,64 Z M52.5,44 L57.5,44 L55,54 Z M52.5,54 L57.5,54 L57.5,64 L52.5,64 Z" />

        <!-- Letter D -->
        <path
            android:fillColor="#000000"
            android:fillType="evenOdd"
            android:pathData="M63,44 L68,44 A5,10 0 0,1 68,64 L63,64 Z M65.5,47 L67.5,47 A3,7 0 0,1 67.5,61 L65.5,61 Z" />
    </group>
</vector>
