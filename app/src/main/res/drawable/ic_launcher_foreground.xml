<!--
    Launcher foreground: an open book with three lines of text on each
    page (the "document" motif) and a pair of round reading glasses
    resting above (the "viewer" motif). Solarized palette.

    Adaptive icon canvas is 108x108dp; the safe circle (guaranteed
    visible under any launcher mask) has diameter ~66dp centered at
    (54,54). All content below is kept inside that circle so the icon
    stays intact on circles, squares, rounded squares, and squircles.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ================= OPEN BOOK ================= -->

    <!-- Page fill: a single shape spanning both pages so the centre
         spine sits slightly higher than the outer corners, giving the
         book a gentle open look. -->
    <path
        android:fillColor="#FDF6E3"
        android:pathData="M30,52 L54,50 L78,52 L78,75 L54,73 L30,75 Z" />

    <!-- Left page outline -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#586E75"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M30,52 L54,50 L54,73 L30,75 Z" />

    <!-- Right page outline -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#586E75"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M54,50 L78,52 L78,75 L54,73 Z" />

    <!-- Text lines, left page (document motif) -->
    <path
        android:strokeColor="#93A1A1"
        android:strokeWidth="1.8"
        android:strokeLineCap="round"
        android:pathData="M34,58 L50,57" />
    <path
        android:strokeColor="#93A1A1"
        android:strokeWidth="1.8"
        android:strokeLineCap="round"
        android:pathData="M34,63 L50,62" />
    <path
        android:strokeColor="#93A1A1"
        android:strokeWidth="1.8"
        android:strokeLineCap="round"
        android:pathData="M34,68 L48,67" />

    <!-- Text lines, right page -->
    <path
        android:strokeColor="#93A1A1"
        android:strokeWidth="1.8"
        android:strokeLineCap="round"
        android:pathData="M58,57 L74,58" />
    <path
        android:strokeColor="#93A1A1"
        android:strokeWidth="1.8"
        android:strokeLineCap="round"
        android:pathData="M58,62 L74,63" />
    <path
        android:strokeColor="#93A1A1"
        android:strokeWidth="1.8"
        android:strokeLineCap="round"
        android:pathData="M58,67 L72,68" />

    <!-- ================= READING GLASSES =============== -->

    <!-- Left lens (radius 8, center 40,39) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#268BD2"
        android:strokeWidth="3"
        android:pathData="M40,39 m-8,0 a8,8 0 1,0 16,0 a8,8 0 1,0 -16,0" />

    <!-- Right lens (radius 8, center 68,39) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#268BD2"
        android:strokeWidth="3"
        android:pathData="M68,39 m-8,0 a8,8 0 1,0 16,0 a8,8 0 1,0 -16,0" />

    <!-- Bridge between the lenses -->
    <path
        android:strokeColor="#268BD2"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:pathData="M48,39 L60,39" />

    <!-- Short earpiece stubs angling slightly back -->
    <path
        android:strokeColor="#268BD2"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:pathData="M32,39 L28,41" />
    <path
        android:strokeColor="#268BD2"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:pathData="M76,39 L80,41" />
</vector>
