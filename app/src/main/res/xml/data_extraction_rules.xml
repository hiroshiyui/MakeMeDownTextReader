<?xml version="1.0" encoding="utf-8"?><!--
    Android 12+ data extraction rules. Excludes the app-private
    documents directory from both cloud backup and device-to-device
    transfer, so files placed in the locked private space never leave
    this install.
    See https://developer.android.com/about/versions/12/backup-restore#xml-changes
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="private_documents/" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="private_documents/" />
    </device-transfer>
</data-extraction-rules>
